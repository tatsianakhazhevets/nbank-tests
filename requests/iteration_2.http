  "username": "admin",
  "password": "admin"
}

### T1_P2
// Admin creates a first user
# FIRST USER Authorization: Basic RGFyaXVzOkFBYmIxMSEh
# "username": "Darius"
# "password": "AAbb11!!"
POST http://localhost:4111/api/v1/admin/users
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

{
  "username": "{{$random.name.firstName}}",
  "password": "AAbb11!!",
  "role": "USER"
}

### T1_P3
